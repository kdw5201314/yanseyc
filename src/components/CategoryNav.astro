---
const categories = [
  {
    title: '必去景点',
    desc: '盐湖、关帝庙、永乐宫……',
    href: '/attractions',
    color: 'bg-brick/10 text-brick',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: '国保地图',
    desc: '102处全国重点文保单位',
    href: '/treasures',
    color: 'bg-amber/10 text-amber-dark',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
  {
    title: '美食地图',
    desc: '羊肉泡、大盘鸡、稷山麻花',
    href: '/food',
    color: 'bg-salt-pink/20 text-brick',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
  },
  {
    title: '交通指南',
    desc: '高铁、自驾、市内交通',
    href: '/transport',
    color: 'bg-pool/10 text-pool',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>`,
  },
  {
    title: '实时盐湖',
    desc: '今日盐湖颜色与最佳观赏',
    href: '/saltlake',
    color: 'bg-salt-dark/20 text-amber-dark',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 22V12h6v10"/></svg>`,
  },
  {
    title: '实用信息',
    desc: '开放时间、门票、住宿推荐',
    href: '/essentials',
    color: 'bg-stone/10 text-stone',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
];
---

<section class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink mb-4">六大板块</h2>
      <p class="text-stone max-w-2xl mx-auto">从自然风光到人文古迹，从舌尖美味到实用攻略，全方位带你认识运城</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map((cat) => (
        <a
          href={cat.href}
          class="group p-6 rounded-2xl border border-salt-dark/10 bg-salt hover:shadow-lg hover:shadow-amber/5 transition-all duration-300"
        >
          <div class={`inline-flex p-3 rounded-xl ${cat.color} mb-4`}>
            <Fragment set:html={cat.icon} />
          </div>
          <h3 class="font-display text-xl font-bold text-ink mb-2 group-hover:text-brick transition-colors">
            {cat.title}
          </h3>
          <p class="text-sm text-stone">{cat.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>
