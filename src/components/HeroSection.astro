---
---

<section class="relative h-[80vh] min-h-[500px] flex items-center justify-center overflow-hidden bg-gradient-to-br from-amber/20 via-salt to-salt-pink/20">
  <!-- Decorative shapes -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-20 -right-20 w-96 h-96 bg-amber/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-salt-pink/15 rounded-full blur-3xl"></div>
    <div class="absolute top-1/3 left-1/4 w-64 h-64 bg-pool/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-bold text-ink mb-4 tracking-wide">
      盐色运城
    </h1>
    <p class="text-xl sm:text-2xl text-stone mb-8 font-light tracking-widest">
      本地设计师带你逛运城
    </p>
    <p class="text-base sm:text-lg text-stone/80 max-w-2xl mx-auto mb-10 leading-relaxed">
      从七彩盐湖的晨光到永乐宫的壁画，从102处国保到一碗热腾腾的羊肉泡——用设计师的眼睛，重新发现这座被低估的千年古城。
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/attractions"
        class="inline-flex items-center justify-center px-8 py-3 bg-brick text-white rounded-lg font-medium hover:bg-brick-dark transition-colors shadow-lg shadow-brick/20"
      >
        开始探索
      </a>
      <a
        href="/saltlake"
        class="inline-flex items-center justify-center px-8 py-3 bg-white text-brick border-2 border-brick rounded-lg font-medium hover:bg-brick/5 transition-colors"
      >
        今日盐湖
      </a>
    </div>
  </div>
</section>
