---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const { title = '盐色运城', description = '本地设计师带你逛运城——运城文旅入口', image = '/images/og-default.jpg' } = Astro.props;

const navItems = [
  { label: '首页', href: '/' },
  { label: '必去景点', href: '/attractions' },
  { label: '国保地图', href: '/treasures' },
  { label: '美食地图', href: '/food' },
  { label: '交通指南', href: '/transport' },
  { label: '实时盐湖', href: '/saltlake' },
  { label: '实用信息', href: '/essentials' },
  { label: '反馈建议', href: '/fankui' },
];

const currentPath = Astro.url.pathname;
const siteURL = 'https://www.yanseyc.cn';
const canonicalURL = new URL(currentPath, siteURL).href;
const ogImage = new URL(image, siteURL).href;
const fullPath = currentPath === '/' ? '' : currentPath;

// JSON-LD 结构化数据
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "盐色运城",
  "url": siteURL,
  "description": "运城文旅入口——七彩盐湖、102处国保、地道美食、交通攻略，一站式发现运城之美。",
  "inLanguage": "zh-CN"
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "TouristInformationCenter",
  "name": "盐色运城",
  "url": siteURL,
  "description": "运城文化旅游信息网站，提供景点介绍、盐湖旅游攻略、美食推荐、交通指南等内容。",
  "areaServed": "运城市",
  "knowsLanguage": ["zh-CN"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首页", "item": siteURL }
  ]
};
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="盐色运城" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="zh_CN" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- JSON-LD 结构化数据 -->
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
</head>
<body class="min-h-screen flex flex-col">
  <header class="sticky top-0 z-50 bg-salt/95 backdrop-blur border-b border-salt-dark/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2">
          <img src="/images/logo-4-landscape.png" alt="盐色运城" class="h-9 w-auto" />
          <span class="font-display text-xl font-bold text-brick hidden sm:inline">盐色运城</span>
        </a>
        <nav class="hidden md:flex items-center gap-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
                currentPath === item.href
                  ? 'text-brick bg-brick/10'
                  : 'text-stone hover:text-ink hover:bg-salt-dark/10'
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-stone hover:text-ink hover:bg-salt-dark/10" aria-label="菜单">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-salt-dark/20 bg-salt px-4 py-2 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${
            currentPath === item.href
              ? 'text-brick bg-brick/10'
              : 'text-stone hover:text-ink hover:bg-salt-dark/10'
          }`}
        >
          {item.label}
        </a>
      ))}
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="bg-ink text-white/60 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <h3 class="font-display text-lg font-bold text-white mb-3">盐色运城</h3>
          <p class="text-sm leading-relaxed">本地设计师带你逛运城，发现运城之美。</p>
        </div>
        <div>
          <h3 class="font-display text-lg font-bold text-white mb-3">快速导航</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/attractions" class="hover:text-amber transition-colors">必去景点</a></li>
            <li><a href="/treasures" class="hover:text-amber transition-colors">国保地图</a></li>
            <li><a href="/food" class="hover:text-amber transition-colors">美食地图</a></li>
            <li><a href="/transport" class="hover:text-amber transition-colors">交通指南</a></li>
            <li><a href="/fankui" class="hover:text-amber transition-colors">反馈建议</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-display text-lg font-bold text-white mb-3">关于</h3>
          <p class="text-sm leading-relaxed">由热爱运城的本地人精心打造，用设计师的视角带你重新发现这座城市。</p>
          <p class="text-sm mt-2">yansheyuncheng@gmail.com</p>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-white/10 text-center text-xs">
        <p>© 2026 盐色运城 www.yanseyc.cn 版权所有</p>
        <p class="mt-1">
          <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" class="hover:text-amber transition-colors">晋ICP备2026xxxxxx号</a>
        </p>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  </script>

  <!-- 全站分析追踪 -->
  <script>
    (function() {
      const API = '/api/track';
      const sessionId = 's_' + Date.now() + '_' + Math.random().toString(36).slice(2, 8);
      const pagePath = window.location.pathname;

      // 发送追踪事件
      async function track(type, data) {
        try {
          await fetch(API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type, data, sessionId, page: pagePath, time: Date.now(), ua: navigator.userAgent.slice(0, 200) }),
            keepalive: true
          });
        } catch(e) {}
      }

      // 页面浏览
      track('pageview', { title: document.title, referrer: document.referrer || '' });

      // 全局点击追踪
      document.addEventListener('click', function(e) {
        const el = e.target.closest('a, button, .attraction-card, .guobao-item, .filter-btn, .cta-btn');
        if (!el) return;

        let clickData = { tag: el.tagName, text: (el.textContent || '').trim().slice(0, 60) };

        if (el.tagName === 'A') {
          clickData.href = el.getAttribute('href') || '';
          clickData.type = 'link';
        } else if (el.classList.contains('attraction-card')) {
          clickData.type = 'attraction-card';
          clickData.text = (el.querySelector('h2')?.textContent || '').trim().slice(0, 40);
        } else if (el.classList.contains('guobao-item')) {
          clickData.type = 'guobao-item';
          clickData.text = (el.querySelector('h3')?.textContent || '').trim().slice(0, 40);
        } else if (el.classList.contains('filter-btn')) {
          clickData.type = 'filter';
          clickData.text = el.textContent.trim().slice(0, 20);
        } else {
          clickData.type = 'button';
        }

        track('click', clickData);
      });
    })();
  </script>
</body>
</html>
