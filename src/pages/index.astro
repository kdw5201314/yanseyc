---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import CategoryNav from '../components/CategoryNav.astro';
import SaltLakeToday from '../components/SaltLakeToday.astro';
---

<Layout title="盐色运城 - 本地设计师带你逛运城" description="运城文旅入口——七彩盐湖、102处国保、地道美食、交通攻略，一站式发现运城之美。">
  <HeroSection />

  <SaltLakeToday />

  <CategoryNav />

  <!-- 国保数字冲击区 -->
  <section class="py-20 sm:py-28 bg-ink text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="mb-8">
        <span class="inline-block px-4 py-1 bg-amber/20 text-amber rounded-full text-sm font-medium mb-6">
          全国地级市第一
        </span>
      </div>
      <div class="flex items-baseline justify-center gap-2 mb-4">
        <span class="font-display text-7xl sm:text-8xl md:text-9xl font-bold text-amber leading-none">102</span>
        <span class="text-xl sm:text-2xl text-white/60 font-light">处</span>
      </div>
      <h2 class="font-display text-2xl sm:text-3xl font-bold mb-6 text-white/90">
        全国重点文物保护单位
      </h2>
      <p class="text-white/60 max-w-2xl mx-auto mb-10 leading-relaxed text-lg">
        运城的国保数量在全国地级市中遥遥领先。从唐代的木构建筑到元代的道教壁画，从宋代的砖雕墓葬到明清的城池遗址——这里的每一寸土地都刻着历史的印记。
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto mb-10">
        <div class="p-4 rounded-xl bg-white/5 backdrop-blur">
          <p class="font-display text-3xl font-bold text-amber">28</p>
          <p class="text-sm text-white/50 mt-1">古建筑</p>
        </div>
        <div class="p-4 rounded-xl bg-white/5 backdrop-blur">
          <p class="font-display text-3xl font-bold text-amber">15</p>
          <p class="text-sm text-white/50 mt-1">古墓葬</p>
        </div>
        <div class="p-4 rounded-xl bg-white/5 backdrop-blur">
          <p class="font-display text-3xl font-bold text-amber">22</p>
          <p class="text-sm text-white/50 mt-1">古遗址</p>
        </div>
        <div class="p-4 rounded-xl bg-white/5 backdrop-blur">
          <p class="font-display text-3xl font-bold text-amber">37</p>
          <p class="text-sm text-white/50 mt-1">其他</p>
        </div>
      </div>
      <a
        href="/treasures"
        class="inline-flex items-center gap-2 px-8 py-3 bg-amber text-ink rounded-lg font-medium hover:bg-amber-dark transition-colors"
      >
        探索国保地图
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- CTA 区 -->
  <section class="py-16 sm:py-20 bg-salt">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink mb-4">
        准备出发了吗？
      </h2>
      <p class="text-stone mb-8 max-w-xl mx-auto">
        无论你是第一次来运城，还是想要重新发现家乡之美，盐色运城都会给你不一样的视角。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/transport"
          class="inline-flex items-center justify-center px-6 py-3 bg-brick text-white rounded-lg font-medium hover:bg-brick-dark transition-colors"
        >
          查看交通指南
        </a>
        <a
          href="/essentials"
          class="inline-flex items-center justify-center px-6 py-3 bg-white text-ink border border-salt-dark/20 rounded-lg font-medium hover:bg-white/80 transition-colors"
        >
          实用信息一览
        </a>
      </div>
    </div>
  </section>
</Layout>
