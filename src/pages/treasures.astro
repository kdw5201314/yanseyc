---
import Layout from '../layouts/Layout.astro';
---

<Layout title="国保地图 - 盐色运城" description="运城102处全国重点文物保护单位全览，全国地级市数量第一。">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="text-center mb-12">
      <span class="inline-block px-4 py-1 bg-amber/10 text-amber-dark rounded-full text-sm font-medium mb-4">
        全国地级市 · 排名第一
      </span>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-ink mb-4">国保地图</h1>
      <p class="text-stone max-w-2xl mx-auto text-lg">
        运城拥有102处全国重点文物保护单位，数量在全国地级市中遥遥领先。每一座古建、每一处遗址，都是中华文明的活化石。
      </p>
    </div>

    <!-- 数据概览 -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="p-6 rounded-2xl bg-white border border-salt-dark/10 text-center">
        <p class="font-display text-4xl font-bold text-brick">102</p>
        <p class="text-sm text-stone mt-1">国保总数</p>
      </div>
      <div class="p-6 rounded-2xl bg-white border border-salt-dark/10 text-center">
        <p class="font-display text-4xl font-bold text-amber">28</p>
        <p class="text-sm text-stone mt-1">古建筑</p>
      </div>
      <div class="p-6 rounded-2xl bg-white border border-salt-dark/10 text-center">
        <p class="font-display text-4xl font-bold text-pool">22</p>
        <p class="text-sm text-stone mt-1">古遗址</p>
      </div>
      <div class="p-6 rounded-2xl bg-white border border-salt-dark/10 text-center">
        <p class="font-display text-4xl font-bold text-salt-pink">15</p>
        <p class="text-sm text-stone mt-1">古墓葬</p>
      </div>
    </div>

    <!-- 重点国保列表 -->
    <div class="space-y-6">
      <h2 class="font-display text-2xl font-bold text-ink">重点推荐</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-xl bg-white border border-salt-dark/10 hover:border-amber/30 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-ink">解州关帝庙</h3>
              <p class="text-sm text-stone mt-1">第三批国保 · 古建筑</p>
            </div>
            <span class="px-2 py-1 bg-brick/10 text-brick text-xs rounded">盐湖区</span>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-white border border-salt-dark/10 hover:border-amber/30 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-ink">永乐宫</h3>
              <p class="text-sm text-stone mt-1">第一批国保 · 古建筑</p>
            </div>
            <span class="px-2 py-1 bg-brick/10 text-brick text-xs rounded">芮城县</span>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-white border border-salt-dark/10 hover:border-amber/30 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-ink">广仁王庙</h3>
              <p class="text-sm text-stone mt-1">第五批国保 · 古建筑</p>
            </div>
            <span class="px-2 py-1 bg-brick/10 text-brick text-xs rounded">芮城县</span>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-white border border-salt-dark/10 hover:border-amber/30 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-ink">万荣东岳庙</h3>
              <p class="text-sm text-stone mt-1">第三批国保 · 古建筑</p>
            </div>
            <span class="px-2 py-1 bg-brick/10 text-brick text-xs rounded">万荣县</span>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-white border border-salt-dark/10 hover:border-amber/30 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-ink">司马光墓</h3>
              <p class="text-sm text-stone mt-1">第三批国保 · 古墓葬</p>
            </div>
            <span class="px-2 py-1 bg-brick/10 text-brick text-xs rounded">夏县</span>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-white border border-salt-dark/10 hover:border-amber/30 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-ink">西阴村遗址</h3>
              <p class="text-sm text-stone mt-1">第四批国保 · 古遗址</p>
            </div>
            <span class="px-2 py-1 bg-brick/10 text-brick text-xs rounded">夏县</span>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-white border border-salt-dark/10 hover:border-amber/30 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-ink">普救寺</h3>
              <p class="text-sm text-stone mt-1">第四批国保 · 古建筑</p>
            </div>
            <span class="px-2 py-1 bg-brick/10 text-brick text-xs rounded">永济市</span>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-white border border-salt-dark/10 hover:border-amber/30 transition-colors">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-ink">万荣后土庙</h3>
              <p class="text-sm text-stone mt-1">第四批国保 · 古建筑</p>
            </div>
            <span class="px-2 py-1 bg-brick/10 text-brick text-xs rounded">万荣县</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 地图占位 -->
    <div class="mt-12">
      <h2 class="font-display text-2xl font-bold text-ink mb-6">分布地图</h2>
      <div class="aspect-[16/9] rounded-2xl bg-gradient-to-br from-salt-dark/10 to-amber/10 border border-salt-dark/10 flex items-center justify-center">
        <div class="text-center">
          <svg class="w-16 h-16 mx-auto text-salt-dark/30 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0121 18.382V7.618a1 1 0 01-.553-.894L15 7m0 13V7"/>
          </svg>
          <p class="text-stone text-sm">交互式国保分布地图（开发中）</p>
          <p class="text-stone/50 text-xs mt-1">将标注全部102处国保单位的位置与信息</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
