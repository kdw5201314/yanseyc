---
---

<section class="relative h-[85vh] min-h-[550px] flex items-center justify-center overflow-hidden">
  <!-- Hero Background Image -->
  <div class="absolute inset-0">
    <img
      src="/images/hero-salt-lake.png"
      alt="运城七彩盐湖"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Gradient overlays for text readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/50"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-ink/50 via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-bold text-white mb-4 tracking-wide drop-shadow-lg">
      盐色运城
    </h1>
    <p class="text-xl sm:text-2xl text-white/90 mb-8 font-light tracking-widest drop-shadow">
      本地设计师带你逛运城
    </p>
    <p class="text-base sm:text-lg text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed drop-shadow">
      从七彩盐湖的晨光到永乐宫的壁画，从102处国保到一碗热腾腾的羊肉泡——用设计师的眼睛，重新发现这座被低估的千年古城。
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/attractions"
        class="inline-flex items-center justify-center px-8 py-3 bg-brick text-white rounded-lg font-medium hover:bg-brick-dark transition-colors shadow-lg shadow-brick/20"
      >
        开始探索
      </a>
      <a
        href="/saltlake"
        class="inline-flex items-center justify-center px-8 py-3 bg-white/90 backdrop-blur text-brick border-2 border-white/30 rounded-lg font-medium hover:bg-white hover:border-brick transition-colors"
      >
        今日盐湖
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
